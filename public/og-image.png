<!-- This would be a real PNG image, but for now I'll create an SVG that can be converted -->
<svg width="1200" height="630" viewBox="0 0 1200 630" fill="none" xmlns="http://www.w3.org/2000/svg">
  <!-- Victorian-inspired background -->
  <rect width="1200" height="630" fill="#fbfef9"/>
  
  <!-- Decorative border -->
  <rect x="20" y="20" width="1160" height="590" fill="none" stroke="#a63446" stroke-width="4"/>
  <rect x="40" y="40" width="1120" height="550" fill="none" stroke="#0c6291" stroke-width="2"/>
  
  <!-- Main content -->
  <text x="600" y="200" font-family="Georgia, serif" font-size="72" font-weight="bold" text-anchor="middle" fill="#a63446">
    LingoPancar
  </text>
  
  <text x="600" y="280" font-family="Georgia, serif" font-size="32" text-anchor="middle" fill="#0c6291">
    Learn Languages with Elegance
  </text>
  
  <!-- Decorative elements -->
  <circle cx="100" cy="100" r="30" fill="#3d7b46" opacity="0.3"/>
  <circle cx="1100" cy="530" r="30" fill="#3d7b46" opacity="0.3"/>
  
  <!-- Bottom text -->
  <text x="600" y="400" font-family="Arial, sans-serif" font-size="24" text-anchor="middle" fill="#080f0f">
    Master vocabulary with beautiful flashcards
  </text>
  
  <text x="600" y="450" font-family="Arial, sans-serif" font-size="20" text-anchor="middle" fill="#080f0f" opacity="0.8">
    German • English • Turkish • Dutch • Japanese • Spanish • Portuguese
  </text>
  
  <!-- URL -->
  <text x="600" y="560" font-family="Arial, sans-serif" font-size="18" text-anchor="middle" fill="#080f0f" opacity="0.6">
    lingoPancar.github.io
  </text>
</svg>
